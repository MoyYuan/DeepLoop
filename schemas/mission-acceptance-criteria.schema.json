{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeepLoop Mission Acceptance Criteria",
  "type": "object",
  "properties": {
    "min_methods_evaluated": { "type": "integer", "minimum": 0 },
    "min_novel_methods_proposed": { "type": "integer", "minimum": 0 },
    "min_llm_text_methods_evaluated": { "type": "integer", "minimum": 0 },
    "require_leaderboard": { "type": "boolean" },
    "require_prediction_files": { "type": "boolean" },
    "require_horizon_metrics": { "type": "boolean" },
    "require_failure_log_for_skipped_methods": { "type": "boolean" },
    "allow_final_report_only_if_criteria_met": { "type": "boolean" }
  },
  "additionalProperties": true
}
