{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeepLoop Release Candidate Review",
  "type": "object",
  "required": [
    "schema_version",
    "policy_name",
    "policy_version",
    "generated_at",
    "package_id",
    "mission_id",
    "package_root",
    "package_manifest_path",
    "package_digest",
    "package_claim_state",
    "gate_2_runtime_contract",
    "decision",
    "eligible_for_promotion",
    "gates",
    "failed_gate_ids",
    "blocking_reasons",
    "required_reviews",
    "missing_reviews",
    "review_artifacts",
    "next_actions"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 2 },
    "policy_name": { "type": "string", "minLength": 1 },
    "policy_version": { "type": "integer", "minimum": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "package_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "package_root": { "type": "string", "minLength": 1 },
    "package_manifest_path": { "type": "string", "minLength": 1 },
    "package_digest": { "type": "string", "minLength": 8 },
    "package_claim_state": { "type": "string", "minLength": 1 },
    "gate_2_runtime_contract": {
      "type": "object",
      "required": [
        "policy_path",
        "phase_id",
        "baseline_boundary",
        "proof_boundary",
        "required_lanes"
      ],
      "properties": {
        "policy_path": { "type": "string", "minLength": 1 },
        "phase_id": { "type": "string", "minLength": 1 },
        "baseline_boundary": {
          "type": "object",
          "required": ["provider_free_smoke", "docker_clean_room"],
          "properties": {
            "provider_free_smoke": { "type": "string", "minLength": 1 },
            "docker_clean_room": { "type": "string", "minLength": 1 },
            "notes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "proof_boundary": {
          "type": "object",
          "required": [
            "fresh_environment_required",
            "bootstrap_without_hidden_state",
            "durable_mission_runtime_evidence_required",
            "manual_machine_auth_remains_explicit",
            "commercial_openai_compatible_lane_required"
          ],
          "properties": {
            "fresh_environment_required": { "type": "boolean" },
            "bootstrap_without_hidden_state": { "type": "boolean" },
            "durable_mission_runtime_evidence_required": { "type": "boolean" },
            "manual_machine_auth_remains_explicit": { "type": "boolean" },
            "commercial_openai_compatible_lane_required": { "type": "boolean" },
            "notes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "required_lanes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "lane_id",
              "category",
              "selection_profile",
              "provider_family",
              "backend",
              "model_expectation",
              "proof_requirements"
            ],
            "properties": {
              "lane_id": { "type": "string", "minLength": 1 },
              "category": { "type": "string", "minLength": 1 },
              "selection_profile": { "type": "string", "minLength": 1 },
              "provider_family": { "type": "string", "minLength": 1 },
              "backend": { "type": "string", "minLength": 1 },
              "model_expectation": { "type": "object" },
              "auth_boundary": { "type": "object" },
              "proof_requirements": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "decision": { "type": "string", "enum": ["blocked", "promotable"] },
    "eligible_for_promotion": { "type": "boolean" },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gate_id", "description", "status", "details"],
        "properties": {
          "gate_id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["passed", "failed"] },
          "details": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "failed_gate_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blocking_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "review_id",
          "description",
          "status",
          "satisfied",
          "evidence_refs",
          "runtime_metadata",
          "validation_errors"
        ],
        "properties": {
          "review_id": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["satisfied", "missing", "invalid", "pending", "rejected", "needs-follow-up"]
          },
          "satisfied": { "type": "boolean" },
          "reviewer": {
            "type": ["object", "null"],
            "required": ["type", "reviewer_id"],
            "properties": {
              "type": { "type": "string", "enum": ["agent", "human"] },
              "reviewer_id": { "type": "string", "minLength": 1 },
              "role": { "type": ["string", "null"] },
              "display_name": { "type": ["string", "null"] }
            }
          },
          "reviewed_at": { "type": ["string", "null"] },
          "note": { "type": ["string", "null"] },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "runtime_metadata": { "type": "object" },
          "human_override": { "type": "boolean" },
          "validation_errors": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "missing_reviews": {
      "type": "array",
      "items": { "type": "string" }
    },
    "review_artifacts": {
      "type": "object",
      "required": ["json", "markdown", "promotion"],
      "properties": {
        "json": { "type": "string", "minLength": 1 },
        "markdown": { "type": "string", "minLength": 1 },
        "promotion": { "type": ["string", "null"] }
      }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
