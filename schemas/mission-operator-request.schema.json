{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeepLoop Mission Operator Request",
  "type": "object",
  "required": [
    "schema_version",
    "request_id",
    "mission_id",
    "created_at",
    "status",
    "summary",
    "explanation",
    "blocker",
    "context",
    "recommendation",
    "alternatives",
    "next_steps",
    "continue_command"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["open"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "explanation": {
      "type": "string",
      "minLength": 1
    },
    "blocker": {
      "type": "object",
      "required": ["kind", "gate", "risk_class", "label", "reason"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["hard-gate", "authority-boundary", "operator-review", "unrecoverable-failure"]
        },
        "gate": {
          "type": "string",
          "minLength": 1
        },
        "risk_class": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "default_response": {
          "type": ["string", "null"]
        },
        "preferred_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hard_gate_profile": {
          "type": ["string", "null"]
        },
        "details": {
          "type": "object",
          "properties": {
            "queue_name": {
              "type": ["string", "null"]
            },
            "blocked_entries": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["entry_id", "queue_name"],
                "properties": {
                  "entry_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "queue_name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "summary_json_path": {
                    "type": ["string", "null"]
                  },
                  "summary_markdown_path": {
                    "type": ["string", "null"]
                  },
                  "sanity_verdict": {
                    "type": ["string", "null"]
                  },
                  "top_blocking_reasons": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "required": [
        "mission_state_path",
        "runtime_root",
        "mode",
        "phase",
        "decision_id",
        "decision_type",
        "action_id",
        "action_kind",
        "executor_id"
      ],
      "properties": {
        "mission_state_path": {
          "type": "string",
          "minLength": 1
        },
        "runtime_root": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "next_phase": {
          "type": ["string", "null"]
        },
        "decision_id": {
          "type": "string",
          "minLength": 1
        },
        "decision_type": {
          "type": "string",
          "minLength": 1
        },
        "action_id": {
          "type": "string",
          "minLength": 1
        },
        "action_kind": {
          "type": "string",
          "minLength": 1
        },
        "action_task": {
          "type": ["string", "null"]
        },
        "branch_id": {
          "type": ["string", "null"]
        },
        "executor_id": {
          "type": "string",
          "minLength": 1
        },
        "blocked_entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["entry_id", "queue_name"],
            "properties": {
              "entry_id": {
                "type": "string",
                "minLength": 1
              },
              "queue_name": {
                "type": "string",
                "minLength": 1
              },
              "summary_json_path": {
                "type": ["string", "null"]
              },
              "summary_markdown_path": {
                "type": ["string", "null"]
              },
              "sanity_verdict": {
                "type": ["string", "null"]
              },
              "top_blocking_reasons": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "recommendation": {
      "type": "object",
      "required": ["summary", "pros", "cons"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "pros": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "auto_triage": {
      "type": "object",
      "required": ["status", "summary"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["completed", "blocked", "failed"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "recommended_operator_action": {
          "type": ["string", "null"]
        },
        "recommended_resume_action": {
          "type": ["string", "null"]
        },
        "report_json_path": {
          "type": ["string", "null"]
        },
        "completed_at": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["option_id", "summary", "pros", "cons", "next_steps"],
        "properties": {
          "option_id": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "pros": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "cons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "next_steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "continue_command": {
      "type": "string",
      "minLength": 1
    },
    "operator_response": {
      "type": ["object", "null"],
      "required": ["action", "recorded_at", "command"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["retry", "reroute"]
        },
        "recorded_at": {
          "type": "string"
        },
        "note": {
          "type": ["string", "null"]
        },
        "command": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
